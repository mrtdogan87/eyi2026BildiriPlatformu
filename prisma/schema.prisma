generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  ACCEPTED
  REJECTED
}

enum SubmissionLanguage {
  TR
  EN
}

enum PresentationMode {
  ONLINE
  IN_PERSON
}

enum PaymentPeriod {
  EARLY
  LATE
}

enum AudienceType {
  ACADEMIC
  STUDENT
}

enum AttendeeRole {
  PRESENTER
  LISTENER
}

model Congress {
  id                String        @id @default(cuid())
  slug              String        @unique
  name              String
  earlyDeadline     DateTime?
  lateDeadline      DateTime?
  galaFeeAmount     Int           @default(0)
  galaFeeCurrency   String        @default("EUR")
  galaFeeNote       String?
  bankName          String?
  bankAccountHolder String?
  bankIban          String?
  bankBranch        String?
  tripNote          String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  submissions       Submission[]
  paymentTiers      PaymentTier[]
}

model PaymentTier {
  id               String           @id @default(cuid())
  congressId       String
  presentationMode PresentationMode
  role             AttendeeRole
  audience         AudienceType?
  onlinePaperCount Int?
  period           PaymentPeriod?
  amount           Int              @default(0)
  currency         String           @default("TRY")
  active           Boolean          @default(true)
  sortOrder        Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  congress         Congress         @relation(fields: [congressId], references: [id], onDelete: Cascade)
  submissions      Submission[]

  @@unique([congressId, presentationMode, role, audience, onlinePaperCount, period])
  @@index([congressId, active])
}

model Submission {
  id                 String                    @id @default(cuid())
  congressId         String
  status             SubmissionStatus          @default(DRAFT)
  submissionLanguage SubmissionLanguage?
  titleTr            String?
  titleEn            String?
  abstractTr         String?
  abstractEn         String?
  keywordsTr         String?
  keywordsEn         String?
  presentationMode   PresentationMode?
  attendeeRole       AttendeeRole?
  audience           AudienceType?
  onlinePaperCount   Int?
  paymentTierId      String?
  paymentPeriod      PaymentPeriod?
  paymentAmount      Int?
  paymentCurrency    String?
  paymentDescription String?
  galaAttendance     Boolean                   @default(false)
  galaAttendeeCount  Int                       @default(0)
  galaFeeAmount      Int?
  galaFeeCurrency    String?
  tripAttendance     Boolean                   @default(false)
  tripAttendeeCount  Int                       @default(0)
  draftOwnerEmail    String
  submittedAt        DateTime?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  congress           Congress                  @relation(fields: [congressId], references: [id], onDelete: Cascade)
  paymentTier        PaymentTier?              @relation(fields: [paymentTierId], references: [id])
  authors            SubmissionAuthor[]
  file               SubmissionFile?
  paymentReceipt     SubmissionPaymentReceipt?
  accessTokens       SubmissionAccessToken[]
  statusHistory      SubmissionStatusHistory[]

  @@index([congressId, status])
  @@index([draftOwnerEmail])
}

model SubmissionAuthor {
  id           String     @id @default(cuid())
  submissionId String
  fullName     String
  email        String
  institution  String?
  country      String?
  isPresenter  Boolean    @default(false)
  sortOrder    Int
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, email])
  @@index([submissionId])
  @@index([email])
}

model SubmissionFile {
  id           String     @id @default(cuid())
  submissionId String     @unique
  originalName String
  mimeType     String
  fileSize     Int
  storageKey   String
  content      Bytes?
  uploadedAt   DateTime   @default(now())
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model SubmissionPaymentReceipt {
  id           String     @id @default(cuid())
  submissionId String     @unique
  originalName String
  mimeType     String
  fileSize     Int
  storageKey   String
  content      Bytes?
  uploadedAt   DateTime   @default(now())
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model SubmissionAccessToken {
  id           String     @id @default(cuid())
  submissionId String
  email        String
  tokenHash    String
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime   @default(now())
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([email])
  @@index([expiresAt])
}

model SubmissionStatusHistory {
  id           String            @id @default(cuid())
  submissionId String
  fromStatus   SubmissionStatus?
  toStatus     SubmissionStatus
  note         String?
  changedAt    DateTime          @default(now())
  submission   Submission        @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId, changedAt])
}
